<style>
  .inscripcion-banner {
    box-shadow: 0 2px 10px -2px rgba(13, 148, 136, 0.25);
  }
  
  .inscripcion-banner.hidden {
    display: none !important;
  }

  .barra-llamativa {
    display: inline-block;
    width: 8px;
    height: 2em;
    background: #ef4444;
    border-radius: 2px;
    animation: parpadeo-bar 1s ease-in-out infinite;
    box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
  }

  @keyframes parpadeo-bar {
    0%, 100% { opacity: 1; transform: scaleY(1); }
    50% { opacity: 0.4; transform: scaleY(0.7); }
  }
</style>
